{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [],
  "globalPassThroughEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "outputs": [".next/**", "dist/**", "build/**", "out/**"],
      "cache": false,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": false
    },
    "type-check": {
      "cache": false
    }
  }
}
