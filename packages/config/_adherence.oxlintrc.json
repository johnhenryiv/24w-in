{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/**",
              "slides/**",
              "social/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bebas Neue|DM Sans|Atkinson Hyperlegible Next))/i]",
        "message": "Font not provided by the design system. Available: Bebas Neue, DM Sans, Atkinson Hyperlegible Next."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|category|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, category, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|tint)$/]",
        "message": "<Badge> variant must be one of 'outline' | 'tint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|active|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|chip)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'chip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|title|meta|status|category|href|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<DocCard> doesn't accept that prop. Declared props: index, title, meta, status, category, href, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|category|corner|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Stamp> doesn't accept that prop. Declared props: children, category, corner, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StampCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:stamp|category|corner|tag|title|description|href|onClick|minHeight|className|style|key|ref|className|style|children)$/]",
        "message": "<StampCard> doesn't accept that prop. Declared props: stamp, category, corner, tag, title, description, href, onClick, minHeight, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|category|as|className|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, category, as, className, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
      },
      "Button": {
        "replaces": []
      },
      "DocCard": {
        "replaces": []
      },
      "Stamp": {
