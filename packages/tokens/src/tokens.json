{
  "$meta": {
    "name": "24W.IN Design Tokens",
    "version": "1.0",
    "date": "2026-05-29",
    "owner": "Tony Cu — The Prana Group, LLC. (Detroit, MI)",
    "provenance": "Reconciled from 24w-design-guidebook.html + 24win-brand-toolkit.html; light theme & AA tuning informed by the A24 x Braille Institute PDF. Primary accent unified to #e8006b (--brand); guidebook's #d946a8 retained as brand-legacy.",
    "usage": "Source of truth. tokens.css mirrors this 1:1. Do not hard-code values downstream."
  },
  "font": {
    "display": "'Bebas Neue', Impact, sans-serif",
    "body": "'DM Sans', 'Inter', 'Helvetica Neue', sans-serif",
    "bodyA11y": "'Atkinson Hyperlegible Next', 'DM Sans', sans-serif",
    "mono": "'Courier New', ui-monospace, monospace"
  },
  "fontSize": {
    "xs": "clamp(0.75rem, 0.70rem + 0.25vw, 0.875rem)",
    "sm": "clamp(0.875rem, 0.80rem + 0.35vw, 1rem)",
    "base": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",
    "lg": "clamp(1.125rem, 1.00rem + 0.75vw, 1.5rem)",
    "xl": "clamp(1.5rem, 1.20rem + 1.25vw, 2.25rem)",
    "2xl": "clamp(2rem, 1.20rem + 2.50vw, 3.5rem)",
    "3xl": "clamp(2.5rem, 1.00rem + 4.00vw, 5rem)",
    "hero": "clamp(3rem, 0.50rem + 7.00vw, 8rem)",
    "stamp": "clamp(4rem, 2.00rem + 10.0vw, 12rem)"
  },
  "space": {
    "_note": "Fibonacci-derived. Marked F values are true sequence members (8,13,21,34,55,89px).",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.8125rem",
    "4": "1rem",
    "5": "1.3125rem",
    "6": "1.5rem",
    "8": "2.125rem",
    "10": "2.5rem",
    "12": "3.4375rem",
    "16": "4rem",
    "20": "5.5625rem",
    "24": "6rem",
    "fibonacci_px": [8, 13, 21, 34, 55, 89]
  },
  "radius": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px"
  },
  "transition": {
    "interactive": "180ms cubic-bezier(0.16, 1, 0.3, 1)",
    "scene": "600ms cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "layout": {
    "contentWide": "1280px",
    "contentDefault": "960px"
  },
  "stampOpacity": { "min": 0.13, "max": 0.25 },
  "theme": {
    "dark": {
      "bg": "#0e0d0c",
      "surface": "#141312",
      "surface2": "#1a1917",
      "surface3": "#201f1d",
      "surfaceOff": "#1f1e1c",
      "divider": "#2e2d2b",
      "border": "rgba(255,255,255,0.10)",
      "text": "#e8e6e3",
      "textMuted": "#8a8885",
      "textFaint": "#5a5957",
      "textInv": "#0e0d0c",
      "brand": "#e8006b",
      "brandHover": "#ff1a7e",
      "brandLegacy": "#d946a8",
      "category": {
        "number": "#e8006b",
        "verb": "#3b82f6",
        "project": "#d4a017",
        "place": "#22c55e",
        "name": "#a855f7",
        "tool": "#0ea5e9"
      },
      "shadow": {
        "sm": "0 1px 2px rgba(0,0,0,0.40)",
        "md": "0 4px 24px rgba(0,0,0,0.45)",
        "lg": "0 12px 48px rgba(0,0,0,0.60)"
      }
    },
    "light": {
      "bg": "#f5f4f0",
      "surface": "#faf9f6",
      "surface2": "#ffffff",
      "surface3": "#efedea",
      "surfaceOff": "#eeece8",
      "divider": "#d8d6d1",
      "border": "rgba(20,19,18,0.12)",
      "text": "#1a1917",
      "textMuted": "#5c5a57",
      "textFaint": "#9a9894",
      "textInv": "#f5f4f0",
      "brand": "#c1005a",
      "brandHover": "#e8006b",
      "brandLegacy": "#b13d88",
      "category": {
        "number": "#c1005a",
        "verb": "#1d4ed8",
        "project": "#9a7400",
        "place": "#15803d",
        "name": "#7e22ce",
        "tool": "#0369a1"
      },
      "shadow": {
        "sm": "0 1px 2px rgba(40,38,34,0.06)",
        "md": "0 4px 24px rgba(40,38,34,0.10)",
        "lg": "0 12px 48px rgba(40,38,34,0.14)"
      }
    }
  },
  "stampModes": {
    "_note": "What can live in a stamp, and its category color (Guidebook §05).",
    "numbers":  { "color": "number",  "useWhen": "Sequences, rankings, indexes, the 24 Ways list" },
    "verbs":    { "color": "verb",    "useWhen": "Sprint themes, campaign words, calls to action" },
    "projects": { "color": "project", "useWhen": "Subdomain cards, project spotlights, case studies" },
    "places":   { "color": "place",   "useWhen": "Location pages, event cards, origin stories" },
    "names":    { "color": "name",    "useWhen": "People cards, collaborator spotlights, attribution" },
    "tools":    { "color": "tool",    "useWhen": "Stack cards, tool spotlights, tech index" },
    "dates":    { "color": "textFaint", "useWhen": "Archive pages, timelines, year-in-review" },
    "concepts": { "color": "number",  "useWhen": "Glossary, idea cards, second-brain, philosophy" }
  }
}
